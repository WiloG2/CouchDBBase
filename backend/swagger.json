{
  "openapi": "3.0.0",
  "info": {
    "title": "E-Commerce API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Customer login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "examples": {
                "validLogin": {
                  "value": {
                    "username": "juan",
                    "password": "123456"
                  }
                },
                "adminLogin": {
                  "value": {
                    "username": "admin",
                    "password": "admin123"
                  }
                }
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login result"
          }
        }
      }
    },
    "/products/search": {
      "post": {
        "summary": "Flexible product search",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductSelector"
              },
              "example": {
                "selector": {
                  "category": "computers"
                },
                "limit": 10
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Product matches"
          }
        }
      }
    },
    "/account/recovery/lookup": {
      "post": {
        "summary": "Account recovery lookup",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AccountLookupRequest"
              },
              "example": {
                "username": "juan"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account lookup result"
          }
        }
      }
    },
    "/catalog/search": {
      "post": {
        "summary": "Public catalog search",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CatalogSearchRequest"
              },
              "example": {
                "category": "computers",
                "maxPrice": 1000
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Product matches"
          },
          "400": {
            "description": "Generic invalid query error"
          }
        }
      }
    },
    "/orders/search": {
      "post": {
        "summary": "Support order search",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderSelector"
              },
              "example": {
                "status": "paid"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order matches"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "properties": {
          "username": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "additionalProperties": true
              }
            ],
            "example": "juan"
          },
          "password": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "additionalProperties": true
              }
            ],
            "example": "123456"
          },
          "selector": {
            "type": "object",
            "additionalProperties": true,
            "example": {
              "username": "admin",
              "password": {
                "$ne": null
              }
            }
          },
          "limit": {
            "type": "integer",
            "example": 1
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "_id",
              "username",
              "role"
            ]
          },
          "execution_stats": {
            "type": "boolean",
            "example": true
          }
        },
        "additionalProperties": true
      },
      "AccountLookupRequest": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "example": "juan"
          },
          "email": {
            "type": "string",
            "example": "juan@test.com"
          },
          "role": {
            "type": "string",
            "example": "user"
          },
          "selector": {
            "type": "object",
            "additionalProperties": true,
            "example": {
              "username": {
                "$exists": true
              }
            }
          },
          "limit": {
            "type": "integer",
            "example": 1
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "_id",
              "username"
            ]
          },
          "execution_stats": {
            "type": "boolean",
            "example": true
          }
        },
        "additionalProperties": true
      },
      "ProductSelector": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Laptop Gamer"
          },
          "category": {
            "type": "string",
            "example": "computers"
          },
          "featured": {
            "type": "boolean",
            "example": true
          },
          "price": {
            "type": "number",
            "example": 1500
          },
          "stock": {
            "type": "integer",
            "example": 5
          },
          "selector": {
            "type": "object",
            "additionalProperties": true,
            "example": {
              "category": "computers"
            }
          },
          "limit": {
            "type": "integer",
            "example": 10
          },
          "skip": {
            "type": "integer",
            "example": 0
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "_id",
              "name",
              "price"
            ]
          },
          "sort": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            },
            "example": [
              {
                "price": "asc"
              }
            ]
          },
          "execution_stats": {
            "type": "boolean",
            "example": true
          },
          "conflicts": {
            "type": "boolean",
            "example": true
          },
          "use_index": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "_design/idx_category",
              "idx_category"
            ]
          },
          "allow_fallback": {
            "type": "boolean",
            "example": false
          }
        },
        "additionalProperties": true
      },
      "CatalogSearchRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Laptop Gamer"
          },
          "category": {
            "type": "string",
            "example": "computers"
          },
          "featured": {
            "type": "boolean",
            "example": true
          },
          "maxPrice": {
            "type": "number",
            "example": 1000
          }
        },
        "additionalProperties": false
      },
      "OrderSelector": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "example": "juan"
          },
          "status": {
            "type": "string",
            "example": "paid"
          },
          "total": {
            "type": "number",
            "example": 1620
          },
          "shippingCity": {
            "type": "string",
            "example": "Quito"
          },
          "paymentLast4": {
            "type": "string",
            "example": "1111"
          },
          "selector": {
            "type": "object",
            "additionalProperties": true,
            "example": {
              "status": "paid"
            }
          },
          "limit": {
            "type": "integer",
            "example": 10
          },
          "skip": {
            "type": "integer",
            "example": 0
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "_id",
              "status",
              "total"
            ]
          },
          "sort": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            },
            "example": [
              {
                "createdAt": "desc"
              }
            ]
          },
          "execution_stats": {
            "type": "boolean",
            "example": true
          }
        },
        "additionalProperties": true
      }
    }
  }
}
