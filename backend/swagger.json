{
  "openapi": "3.0.0",
  "info": {
    "title": "E-Commerce API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "paths": {
    "/login": {
      "post": {
        "summary": "User login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/products/search": {
      "post": {
        "summary": "Search products",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductSelector"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Products list"
          }
        }
      }
    },
    "/admin/users": {
      "get": {
        "summary": "Get admin users",
        "responses": {
          "200": {
            "description": "List users"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Alternate customer login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "examples": {
                "validLogin": {
                  "value": {
                    "username": "juan",
                    "password": "123456"
                  }
                },
                "adminLogin": {
                  "value": {
                    "username": "admin",
                    "password": "admin123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login result"
          }
        }
      }
    },
    "/account/recovery/lookup": {
      "post": {
        "summary": "Account recovery lookup",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AccountLookupRequest"
              },
              "example": {
                "username": "juan"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account lookup result"
          }
        }
      }
    },
    "/reports/products": {
      "post": {
        "summary": "Internal product inventory report",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductSelector"
              },
              "example": {
                "category": "computers",
                "featured": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Product matches"
          },
          "500": {
            "description": "Report generation error"
          }
        }
      }
    },
    "/catalog/search": {
      "post": {
        "summary": "Public catalog search",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CatalogSearchRequest"
              },
              "example": {
                "category": "computers",
                "maxPrice": 1000
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Product matches"
          },
          "400": {
            "description": "Generic invalid query error"
          }
        }
      }
    },
    "/catalog/advanced-search": {
      "post": {
        "summary": "Advanced catalog search for inventory analysts",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductSelector"
              },
              "example": {
                "category": "computers",
                "maxPrice": 1000
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Products and query metadata"
          }
        }
      }
    },
    "/security/request-risk": {
      "post": {
        "summary": "Request risk evaluation",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RiskReviewRequest"
              },
              "example": {
                "path": "/orders/search",
                "filters": {
                  "status": "paid"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Suspicion flag and elapsed time"
          }
        }
      }
    },
    "/security/filter-review": {
      "post": {
        "summary": "Review dynamic filters submitted by integrations",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RiskReviewRequest"
              },
              "example": {
                "source": "partner-api",
                "filters": {
                  "category": "computers",
                  "featured": true
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Risk assessment"
          }
        }
      }
    },
    "/orders/search": {
      "post": {
        "summary": "Support order search",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderSelector"
              },
              "example": {
                "status": "paid"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order matches"
          }
        }
      }
    },
    "/admin/staff-directory": {
      "get": {
        "summary": "Legacy staff directory",
        "responses": {
          "200": {
            "description": "List privileged users"
          }
        }
      }
    },
    "/admin/staff": {
      "get": {
        "summary": "Protected staff directory",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "List privileged users"
          },
          "401": {
            "description": "Invalid token"
          },
          "403": {
            "description": "Missing token or insufficient permissions"
          }
        }
      }
    },
    "/products/catalog": {
      "post": {
        "summary": "Frontend product catalog search",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CatalogSearchRequest"
              },
              "example": {
                "category": "computers",
                "maxPrice": 1000
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Product matches"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "properties": {
          "username": {
            "type": "string",
            "example": "juan"
          },
          "password": {
            "type": "string",
            "example": "123456"
          }
        },
        "additionalProperties": false
      },
      "AccountLookupRequest": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "example": "juan"
          },
          "email": {
            "type": "string",
            "example": "juan@test.com"
          },
          "role": {
            "type": "string",
            "example": "user"
          }
        },
        "additionalProperties": true
      },
      "ProductSelector": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Laptop Gamer"
          },
          "category": {
            "type": "string",
            "example": "computers"
          },
          "featured": {
            "type": "boolean",
            "example": true
          },
          "price": {
            "type": "number",
            "example": 1500
          },
          "stock": {
            "type": "integer",
            "example": 5
          },
          "selector": {
            "type": "object",
            "additionalProperties": true,
            "example": {
              "category": "computers"
            }
          }
        },
        "additionalProperties": true
      },
      "CatalogSearchRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Laptop Gamer"
          },
          "category": {
            "type": "string",
            "example": "computers"
          },
          "featured": {
            "type": "boolean",
            "example": true
          },
          "maxPrice": {
            "type": "number",
            "example": 1000
          }
        },
        "additionalProperties": false
      },
      "RiskReviewRequest": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "example": "/orders/search"
          },
          "source": {
            "type": "string",
            "example": "partner-api"
          },
          "filters": {
            "type": "object",
            "additionalProperties": true,
            "example": {
              "status": "paid"
            }
          },
          "selector": {
            "type": "object",
            "additionalProperties": true,
            "example": {
              "category": "computers"
            }
          }
        },
        "additionalProperties": true
      },
      "OrderSelector": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "example": "juan"
          },
          "status": {
            "type": "string",
            "example": "paid"
          },
          "total": {
            "type": "number",
            "example": 1620
          },
          "shippingCity": {
            "type": "string",
            "example": "Quito"
          },
          "paymentLast4": {
            "type": "string",
            "example": "1111"
          },
          "selector": {
            "type": "object",
            "additionalProperties": true,
            "example": {
              "status": "paid"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
